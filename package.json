{
  "name": "divuga-telegram-automation",
  "version": "1.0.0",
  "description": "Multi-account Telegram automation client",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "backend": "node backend/server.js",
    "frontend": "npm run dev --prefix frontend",
    "dev": "npx concurrently \"npm run backend\" \"npm run frontend\"",
    "build": "npm run build --prefix frontend",
    "install-all": "npm install && npm install --prefix frontend",
    "audit-all": "npm audit && npm audit --prefix frontend && npm audit --prefix backend"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "qrcode": "^1.5.4",
    "telegram": "^2.26.15",
    "uuid": "^11.0.3"
  }
}
